# ─── Supabase ────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ─── Firebase (notificações push / analytics) ────────────────────────────────
VITE_FIREBASE_API_KEY=sua_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxx
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── App URL (usado em e-mails, links e OG tags) ─────────────────────────────
VITE_APP_URL=https://hublocadora.vercel.app

# ─── Sentry (monitoramento de erros em produção) ─────────────────────────────
# DSN do projeto em https://sentry.io → Settings → Client Keys
VITE_SENTRY_DSN=https://xxxxxx@oxxxxxx.ingest.sentry.io/xxxxxxx
SENTRY_SERVER_DSN=https://xxxxxx@oxxxxxx.ingest.sentry.io/xxxxxxx

# ─── Servidor Express / Genkit (backend) ─────────────────────────────────────
# NUNCA use prefixo VITE_ em chaves privadas de backend
GOOGLE_GENAI_API_KEY=sua_gemini_api_key_aqui
ALLOWED_ORIGINS=https://hublocadora.vercel.app
PORT=3001
NODE_ENV=production
